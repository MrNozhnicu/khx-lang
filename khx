def open_docs():
    """Открыть документацию"""
    import webbrowser
    url = "https://github.com/MrNozhnicu/khx-lang"
    print(f"Открытие документации: {url}")
    webbrowser.open(url)


def main():
    """Главная функция CLI"""
    if len(sys.argv) == 1:
        show_help()
        return
    
    arg = sys.argv[1]
    
    # Команды
    if arg == "--version" or arg == "-v":
        show_version()
    elif arg == "--help" or arg == "-h":
        show_help()
    elif arg == "--repl" or arg == "-r":
        run_repl()
    elif arg == "--new":
        if len(sys.argv) < 3:
            print("[ERROR] Укажите имя проекта: khx --new <name>")
        else:
            create_project(sys.argv[2])
    elif arg == "--run":
        if len(sys.argv) < 3:
            print("[ERROR] Укажите файл: khx --run <file>")
        else:
            run_file(sys.argv[2])
    elif arg == "--check":
        if len(sys.argv) < 3:
            print("[ERROR] Укажите файл: khx --check <file>")
        else:
            check_syntax(sys.argv[2])
    elif arg == "--examples":
        show_examples()
    elif arg == "--docs":
        open_docs()
    elif arg.endswith('.khx'):
        # Запустить файл напрямую
        run_file(arg)
    else:
        print(f"[ERROR] Неизвестная команда: {arg}")
        print("Используйте 'khx --help' для справки")


if __name__ == "__main__":
    main()
